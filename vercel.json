{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/workspace", "destination": "/workspace.html" },
    { "source": "/zayvora", "destination": "/zayvora.html" },
    { "source": "/((?!assets/|scripts/|sw.js|manifest.json|.*\\.).*)", "destination": "/index.html" }
  ]
}
