{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.daxini.xyz"
        }
      ],
      "destination": "https://daxini.xyz/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/early-access", "destination": "/zayvora-onboarding/index.html" },
    { "source": "/((?!api/|.*\\.).*)", "destination": "/index.html" }
  ]
}
