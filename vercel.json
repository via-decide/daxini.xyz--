{
  "buildCommand": "echo 'Static build'",
  "outputDirectory": ".",
  "public": true,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/api", "destination": "/api/index.js" },
    { "source": "/zayvora", "destination": "/zayvora.html" },
    { "source": "/zayvora/", "destination": "/zayvora.html" },
    { "source": "/workspace", "destination": "/workspace.html" },
    { "source": "/workspace/", "destination": "/workspace.html" },
    { "source": "/research", "destination": "/research.html" },
    { "source": "/research/", "destination": "/research.html" },
    { "source": "/(.*).html", "destination": "/$1.html" },
    { "source": "/pwa/(.*)", "destination": "/pwa/index.html" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        }
      ]
    }
  ]
}
