{
  "buildCommand": "echo 'Static site - no build required'",
  "outputDirectory": ".",
  "public": true,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/(.*)\\.html$",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    },
    {
      "source": "/(.*)\\.js$",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript; charset=utf-8"
        }
      ]
    },
    {
      "source": "/(.*)\\.css$",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/css; charset=utf-8"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/login",
      "destination": "/ui/auth/login.html"
    },
    {
      "source": "/login/",
      "destination": "/ui/auth/login.html"
    },
    {
      "source": "/zayvora-pricing",
      "destination": "/zayvora-pricing.html"
    },
    {
      "source": "/zayvora-pricing/",
      "destination": "/zayvora-pricing.html"
    },
    {
      "source": "/zayvora-onboarding",
      "destination": "/ui/auth/onboarding.html"
    },
    {
      "source": "/zayvora-onboarding/",
      "destination": "/ui/auth/onboarding.html"
    },
    {
      "source": "/zayvora-chat",
      "destination": "/ui/workspace/index.html"
    },
    {
      "source": "/zayvora-chat/",
      "destination": "/ui/workspace/index.html"
    },
    {
      "source": "/zayvora",
      "destination": "/ui/workspace/mission-control.html"
    },
    {
      "source": "/zayvora/",
      "destination": "/ui/workspace/mission-control.html"
    },
    {
      "source": "/zayvora-dev",
      "destination": "/ui/workspace/dev-workspace.html"
    },
    {
      "source": "/zayvora-dev/",
      "destination": "/ui/workspace/dev-workspace.html"
    },
    {
      "source": "/studyos",
      "destination": "/studyos.html"
    },
    {
      "source": "/studyos/",
      "destination": "/studyos.html"
    },
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
