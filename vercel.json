{
  "cleanUrls": true,
  "env": {
    "ZAYVORA_API": "https://daxini.xyz/api",
    "ZAYVORA_LOGIN_URL": "https://daxini.xyz/login"
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/zayvora/?$",
      "dest": "/zayvora/index.html"
    },
    {
      "src": "^/(.*)$",
      "dest": "/index.html"
      "source": "/zayvora",
      "destination": "/zayvora/index.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
